# ─────────────────────────────────────────────────────────────
#  Aztech LED — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────

# 1. Resend API key (get from https://resend.com → API Keys)
#    Free tier allows 3,000 emails/month — enough for a small business site.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. The email address that receives contact form enquiries
CONTACT_TO_EMAIL=info@ledscreenuae.com

# 3. The "from" email address shown in the enquiry email.
#    IMPORTANT: this domain (ledscreenuae.com) must be verified in Resend.
#    Until domain is verified, you can use: onboarding@resend.dev (Resend sandbox)
CONTACT_FROM_EMAIL=enquiries@ledscreenuae.com
